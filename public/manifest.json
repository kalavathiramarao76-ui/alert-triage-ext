{
  "manifest_version": 3,
  "name": "AI Alert Triage",
  "version": "1.0.0",
  "description": "AI-powered alert triage: priority classification (P0-P4), noise detection, incident creation, and escalation paths",
  "permissions": [
    "sidePanel",
    "activeTab",
    "storage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://sai.sharedllm.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.pagerduty.com/*",
        "https://*.opsgenie.com/*",
        "https://app.opsgenie.com/*"
      ],
      "js": ["content.js"],
      "css": ["assets/content.css"]
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "cors_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
